{
  "experiment_id": "prompt_comparison",
  "description": "Compare full 13-section note template (Variant A) vs compact 8-section template (Variant B).",
  "metric_keys": ["generation_time", "content_length", "section_coverage"],
  "higher_is_better": ["content_length", "section_coverage"],
  "dataset": "app/storage/metadata",
  "variants": [
    {
      "variant": "A",
      "description": "Full 13-section note prompt (current default).",
      "parameters": {"prompt_module": "app.prompts.paper_note_prompt", "expected_sections": 13}
    },
    {
      "variant": "B",
      "description": "Compact 8-section note prompt.",
      "parameters": {"prompt_module": "app.prompts.paper_note_prompt_compact", "expected_sections": 8}
    }
  ]
}
