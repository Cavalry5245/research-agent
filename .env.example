# LLM configuration (OpenAI-compatible API)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat

# Embedding configuration
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=bge-small-zh-v1.5

# Vector store
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=app/storage/vector_db

# Storage paths
UPLOAD_DIR=app/storage/papers
NOTE_DIR=app/storage/notes
METADATA_DIR=app/storage/metadata

# MCP Configuration
MCP_ENABLED=true
MCP_STARTUP_TIMEOUT=10.0
MCP_HEALTH_CHECK_INTERVAL=30.0
MCP_TOOL_TIMEOUT=30.0

# Zotero MCP
ZOTERO_MCP_ENABLED=true
ZOTERO_MCP_AUTO_INSTALL=false
ZOTERO_MCP_COMMAND=
ZOTERO_DATA_DIR=  # Optional: path to Zotero data directory
SEMANTIC_SCHOLAR_MCP_ENABLED=false
ARXIV_MCP_ENABLED=false
RESEARCH_AGENT_MCP_ENABLED=true
